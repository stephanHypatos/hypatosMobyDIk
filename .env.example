# Copy this file to .env and fill in your values.
# .env is gitignored and never pushed to GitHub.

# ── Hypatos API ────────────────────────────────────────────────
HYPATOS_CLIENT_ID=your-client-id
HYPATOS_CLIENT_SECRET=your-client-secret
HYPATOS_REGION=EU          # EU or US

# ── SMTP Email ─────────────────────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=your@email.com
SMTP_PASSWORD=your-password
SMTP_FROM=your@email.com
SMTP_USE_TLS=true          # STARTTLS (port 587)
SMTP_USE_SSL=false         # SSL (port 465) — set true if using port 465

# ── Output ─────────────────────────────────────────────────────
OUTPUT_DIR=./output        # Folder where sorted CSVs are saved
